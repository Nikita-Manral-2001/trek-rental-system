@model TTH.Areas.Super.Models.Rent.RentSliderModel;


<style>
    body {
      background-color: #f8f9fa;
    }
    .form-container {
      margin: 50px auto;
      max-width: 900px;
      padding: 30px;
      background: white;
      border-radius: 10px;
      box-shadow: 0px 0px 10px #ddd;
    }
    .form-title {
      font-size: 1.25rem;
      font-weight: 600;
      margin-bottom: 20px;
    }
    .save-btn {
      background-color: #007bff;
      border: none;
      padding: 10px 20px;
      color: white;
      border-radius: 6px;
    }
    .note {
      font-size: 0.9rem;
      color: #555;
    }
</style>


<div class="container py-4">
    <div class="card shadow-sm border-0 mb-4">

        <div class="card border-bottom border-dark rounded-3">
            <div class="card-header bg-white border-bottom border-dark">
                <h3 class="m-0 fw-semibold text-dark">Add Sliders</h3>
            </div>
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
                    <strong>Success!</strong> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="card-body">
                <form asp-area="Super" asp-controller="RentAdmin" asp-action="AddSliderImage" method="post" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label>Title</label>
                        <input asp-for="Title" class="form-control" />
                    </div>


                    <div class="mb-3">
                        <label>Choose Product</label>
                        <select asp-for="ProductId" class="form-control" asp-items="Model.Products">
                            <option value="">-- Select Product --</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Choose The Slider Images Multiple</label>
                        <input type="file" name="desktopImage" class="form-control" multiple accept=".webp">
                        <div class="note">Note: Desktop Slider || webp file</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Choose The Mobile Slider Images Multiple</label>
                        <input type="file" name="mobileImage" class="form-control" multiple accept=".webp">
                        <div class="note">Note: Mobile Slider || webp file</div>
                    </div>

                    <button type="submit" class="save-btn"><i class="bi bi-save-fill"></i> Save</button>
                </form>
            </div>
        </div>
    </div>
    @if (ViewBag.ExistingSliders != null)
    {
        <div class="mt-4">
            <h5 class="mb-3">Existing Desktop Slider Images</h5>
            <div id="slider-sortable" class="row sortable">
                @foreach (var slider in ViewBag.ExistingSliders)
                {
                    if (!string.IsNullOrEmpty(slider.DesktopImagePath))
                    {
                        <div class="col-md-3 slider-item position-relative mb-4" data-id="@slider.Id">
                            <img src="@slider.DesktopImagePath"
                                 class="img-fluid rounded shadow-sm"
                                 style="height: 150px; width: 100%; object-fit: cover;" />

                            <button type="button"
                                    class="btn-close position-absolute top-0 end-0 m-2"
                                    onclick="deleteSliderImage(@slider.Id, 'desktop')">
                            </button>

                            <p class="text-center mt-2 small">Desktop Image</p>
                        </div>
                    }
                }
            </div>
        </div>

    }



</div>


<script>
    function deleteSliderImage(id, type) {
        if (confirm("Are you sure you want to delete this " + type + " image?")) {
            $.ajax({
                url: '/Super/RentAdmin/DeleteSliderImage',
                type: 'POST',
                data: { id: id, imageType: type },
                success: function (result) {
                    if (result.success) {
                        alert("Image deleted successfully");
                        location.reload();
                    } else {
                        alert("Failed to delete image");
                    }
                },
                error: function () {
                    alert("An error occurred while deleting the image");
                }
            });
        }
    }
</script>


<!-- Load SortableJS -->
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.14.0/Sortable.min.js"></script>

<!-- Then your script that uses Sortable -->
<script>
    $(document).ready(function () {
        new Sortable(document.getElementById('slider-sortable'), {
            animation: 150,
            onUpdate: function (evt) {
                var order = [];
                $("#slider-sortable .slider-item").each(function () {
                    order.push($(this).data("id"));
                });

                $.ajax({
                    url: "/Super/RentAdmin/UpdateSliderOrder",
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify(order),
                    success: function () {
                        console.log("Sort order updated");
                    },
                    error: function () {
                        alert("Error while updating sort order");
                    }
                });
            }
        });
    });
</script>











