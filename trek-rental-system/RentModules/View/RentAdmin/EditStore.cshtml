@model TTH.Areas.Super.Models.Rent.StoresModel;

<div class="container">
    <h2>Edit Store</h2>
    <form asp-action="EditStore" method="post">
        <input type="hidden" name="Store_Id" value="@Model.Store_Id" />
        <div class="form-group">
            <label for="StoreName">Store Name</label>
            <input type="text" class="form-control" id="StoreName" name="StoreName" value="@Model.StoreName" required>
        </div>
        <button type="submit" class="btn btn-primary">Save</button>
    </form>
</div>