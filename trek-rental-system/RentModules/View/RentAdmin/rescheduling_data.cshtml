<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-12">
                <div class="card card-primary card-outline">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-search"></i>

                        </h3>
                    </div>
                    <div class="card-body">

                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group">
                                    <input id="txtSearch" name="txtSearch" class="form-control" placeholder="Enter Email" />
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <button id="btnSearch" type="button" class="btn btn-primary">
                                        <i class="fas fa-search"></i> Search
                                    </button>
                                </div>
                            </div>

                            <!-- Placeholder for the partial view -->

                            <div class="col-md-12">
                                <div id="editUserContainer"></div>
                            </div>
                        </div>




                    </div>
                    <!-- /.card -->
                </div>
            </div>
        </div>
    </div>
</section>
<script>
    $(document).ready(function () {
        $('#btnSearch').on('click', function () {
            // Get the input value
            var email = $('#txtSearch').val();
            if (email === "") {
                alert("Please Enter Email");
                return;
            }

            // Make the AJAX request
            $.ajax({
                url: '/super/RentAdmin/EditUser', // Ensure this matches your route
                type: 'GET',
                data: { email: email },
                success: function (response) {


                  if (response.success === false && response.message === "UserNotFound") {
                        alert("Email not found in the database.");
                    }
                    if (response.success === false && response.etype === "exx") {
                        alert(response.message);
                    }
                    $('#editUserContainer').html(response);

                },
                error: function (xhr, status, error) {
                    console.error('Error fetching partial view:', error);
                }
            });
        });
    });
</script>