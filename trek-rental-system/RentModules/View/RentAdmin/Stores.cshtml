@model IEnumerable<TTH.Areas.Super.Models.Rent.StoresModel>

<div class="container">
    <h2>Stores</h2>
    <form asp-action="AddStore" method="post">
        <div class="form-group">
            <label for="StoreName">Store Name</label>
            <input type="text" class="form-control" id="StoreName" name="StoreName" required>
        </div>
        <button type="submit" class="btn btn-primary">Save</button>
    </form>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Store ID</th>
                <th>Store Name</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var store in Model)
            {
                <tr>
                    <td>@store.Store_Id</td>
                    <td>@store.StoreName</td>
                    <td>
                        <a href="@Url.Action("EditStore", new { id = store.Store_Id })">Edit</a>
                        <form asp-action="DeleteStore" asp-route-id="@store.Store_Id" method="post" style="display:inline;">
                            <button type="submit" class="btn btn-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>