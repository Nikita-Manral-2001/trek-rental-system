<div class="container mt-4">
    <h2 class="mb-4">Add Trek</h2>
    <form asp-action="RentTrek" method="post">
        <div class="form-row">
            <div class="form-group col-md-6">
                <label for="trekName">Trek Name</label>
                <select id="trekName" name="TrekName" class="form-control" asp-items="ViewBag.Treks">
                    <option value="">Select Trek</option>
                </select>
            </div>
            <div class="form-group col-md-6">
                <label for="trekDuration">Trek Duration (Days)</label>
                <input type="number" name="Duration" class="form-control" id="trekDuration" placeholder="Enter trek duration" required>
            </div>
        </div>
        <div class="form-row">
            <div class="form-group col-md-6">
                <label for="rentingWaiting">Renting Waiting</label>
                <input type="text" name="RentingWaiting" class="form-control" id="rentingWaiting">
            </div>
            <div class="form-group col-md-6">
                <label for="blockBefore">Block Before (Days)</label>
                <input type="text" name="BlockBeforeDays" class="form-control" id="blockBefore">
            </div>
        </div>
        <div class="form-group">
            <label for="storeName">Store Name</label>
            <select id="storeName" name="StoreName" class="form-control" asp-items="ViewBag.Stores">
                <option value="">Select Store</option>
            </select>
        </div>
        <button type="submit" class="btn btn-primary">Save</button>
    </form>

    <h2 class="mt-4">Trek List</h2>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Action</th>
                <th>Trek Name</th>
                <th>Duration</th>
                <th>Renting Waiting</th>
                <th>Block Before Days</th>
                <th>Store Name</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var rental in Model)
            {
                <tr>
                    <td>
                        <button type="button" class="btn btn-primary btn-sm edit-btn" data-id="@rental.TrekRentalId">Edit</button>
                        <button type="button" class="btn btn-success btn-sm update-btn" data-id="@rental.TrekRentalId" style="display: none;">Update</button>
                        <button type="button" class="btn btn-danger btn-sm delete-btn" data-id="@rental.TrekRentalId">Delete</button>
                        <button type="button" class="btn btn-secondary btn-sm cancel-btn" data-id="@rental.TrekRentalId" style="display: none;">Cancel</button>
                    </td>
                    <td><span class="view-mode">@rental.TrekName</span><input type="text" class="form-control edit-mode" value="@rental.TrekName" style="display: none;"></td>
                    <td><span class="view-mode">@rental.Duration</span><input type="number" class="form-control edit-mode" value="@rental.Duration" style="display: none;"></td>
                    <td><span class="view-mode">@rental.RentingWaiting</span><input type="text" class="form-control edit-mode" value="@rental.RentingWaiting" style="display: none;"></td>
                    <td><span class="view-mode">@rental.BlockBeforeDays</span><input type="number" class="form-control edit-mode" value="@rental.BlockBeforeDays" style="display: none;"></td>
                    <td><span class="view-mode">@rental.StoreName</span><input type="text" class="form-control edit-mode" value="@rental.StoreName" style="display: none;"></td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script type="text/javascript">
    document.addEventListener("DOMContentLoaded", function () {
        // Handle Delete button
        document.querySelectorAll(".delete-btn").forEach(button => {
            button.addEventListener("click", function () {
                var id = this.getAttribute("data-id");
                if (confirm("Are you sure you want to delete this rental?")) {
                    fetch(`/super/RentAdmin/DeleteTrekRental/${id}`, {
                        method: 'DELETE',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': '@Html.AntiForgeryToken()'
                        }
                    })
                        .then(response => {
                            if (response.ok) {
                                location.reload();
                            } else {
                                alert('Failed to delete the rental.');
                            }
                        })
                        .catch(error => console.error('Error:', error));
                }
            });
        });

        // Handle Edit button
        document.querySelectorAll(".edit-btn").forEach(button => {
            button.addEventListener("click", function () {
                var row = this.closest("tr");
                row.querySelectorAll(".view-mode").forEach(el => el.style.display = "none");
                row.querySelectorAll(".edit-mode").forEach(el => el.style.display = "block");
                row.querySelector(".edit-btn").style.display = "none";
                row.querySelector(".update-btn").style.display = "inline-block";
                row.querySelector(".delete-btn").style.display = "none";
                row.querySelector(".cancel-btn").style.display = "inline-block";
            });
        });

        // Handle Cancel button
        document.querySelectorAll(".cancel-btn").forEach(button => {
            button.addEventListener("click", function () {
                var row = this.closest("tr");
                row.querySelectorAll(".view-mode").forEach(el => el.style.display = "block");
                row.querySelectorAll(".edit-mode").forEach(el => el.style.display = "none");
                row.querySelector(".edit-btn").style.display = "inline-block";
                row.querySelector(".update-btn").style.display = "none";
                row.querySelector(".delete-btn").style.display = "inline-block";
                row.querySelector(".cancel-btn").style.display = "none";
            });
        });

        document.querySelectorAll(".update-btn").forEach(button => {
            button.addEventListener("click", function () {
                var row = this.closest("tr");
                var id = this.getAttribute("data-id");

                var trekRental = {
                    TrekRentalId: id,
                    Duration: row.querySelectorAll("input[type='number']")[0].value, // Include Duration
                    RentingWaiting: row.querySelectorAll("input[type='text']")[1].value,
                    BlockBeforeDays: row.querySelectorAll("input[type='number']")[1].value,
                    StoreName: row.querySelectorAll("input[type='text']")[2].value
                };

                fetch('/super/RentAdmin/UpdateTrekRental', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': '@Html.AntiForgeryToken()'
                    },
                    body: JSON.stringify(trekRental)
                })
                    .then(response => {
                        if (response.ok) {
                            location.reload();
                        } else {
                            return response.text().then(text => {
                                alert(text);  // Display the error message from the server
                            });
                        }
                    })
                    .catch(error => console.error('Error:', error));

            });
        });


        // Handle Trek Name change event
        document.getElementById("trekName").addEventListener("change", function () {
            var trekName = this.value;
            if (trekName) {
                fetch(`/super/RentAdmin/GetTrekDetailsByName/${trekName}`)
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Network response was not ok');
                        }
                        return response.json();
                    })
                    .then(data => {
                        if (data && data.days) {
                            document.getElementById("trekDuration").value = data.days;
                        }
                    })
                    .catch(error => console.error('Error:', error));
            } else {
                document.getElementById("trekDuration").value = "";
            }
        });
    });
</script>