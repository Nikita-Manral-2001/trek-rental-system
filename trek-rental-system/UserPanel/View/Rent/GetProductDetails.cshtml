</div>






<script>
    function getUrlParameter(name) {
        name = name.replace(/[\[]/, '\\[').replace(/[\]]/, '\\]');
        var regex = new RegExp('[\\?&]' + name + '=([^&#]*)');
        var results = regex.exec(location.search);
        return results === null ? '' : decodeURIComponent(results[1].replace(/\+/g, ' '));
    }

    document.getElementById('variant').addEventListener('change', function () {
        updateHiddenFields();
        checkTrekIdInDatabase();  // Trigger when variant is changed
    });

    document.getElementById('quantity').addEventListener('change', function () {
        updateHiddenFields();
        checkTrekIdInDatabase();  // Trigger when quantity is changed
    });

    function updateHiddenFields() {
        var variantSelect = document.getElementById('variant');
        var selectedSizeName = variantSelect ? variantSelect.value : '';  // Check if element exists
        var quantityValue = document.getElementById('quantity') ? document.getElementById('quantity').value : '';

        var userIdElement = document.getElementById('userId');  // Assuming there's an input with ID 'userId'
        var userId = userIdElement ? userIdElement.value : '';

        if (variantSelect && quantityValue) {
            document.querySelector('input[name="variant"]').value = selectedSizeName;
            document.querySelector('input[name="quantity"]').value = quantityValue;
        }
    }

    function checkTrekIdInDatabase() {
        var variantSelect = document.getElementById('variant');
        var selectedSizeName = variantSelect ? variantSelect.value : '';
        var quantityValue = document.getElementById('quantity') ? document.getElementById('quantity').value : '';

        var trekId = document.getElementById('trekId') ? document.getElementById('trekId').value : '';
        var startDate = document.getElementById('startDate') ? document.getElementById('startDate').value : '';
        var blockEndDate = document.querySelector('input[name="blockEndDate"]') ? document.querySelector('input[name="blockEndDate"]').value : '';
        var productId = document.querySelector('input[name="productId"]') ? document.querySelector('input[name="productId"]').value : '';
        var userEmail = document.querySelector('input[name="userEmail"]') ? document.querySelector('input[name="userEmail"]').value : ''; // Get the user email

        if (selectedSizeName && quantityValue) {
            $.ajax({
                url: '/RentCart/CheckTrekId',
                type: 'POST',
                data: {
                    trekId: trekId,
                    startDate: startDate,
                    blockEndDate: blockEndDate,
                    productId: productId,
                    selectedSizeName: selectedSizeName,
                    quantity: quantityValue,
                    userEmail: userEmail // Include the user email in the request
                },
                success: function (response) {
                    var addToCartButton = document.getElementById('addToCartButton');
                    var errorMessage = document.getElementById('error-message');

                    if (response.success) {
                        if (response.isQuantityAvailable) {
                            addToCartButton.disabled = false;
                            errorMessage.style.display = 'none';
                        } else {
                            addToCartButton.disabled = true;
                            errorMessage.style.display = 'block';
                            errorMessage.innerText = 'Quantity not available for this size.';

                            setTimeout(function () {
                                errorMessage.style.display = 'none';
                            }, 5000);
                        }
                    }
                  
                    else {
                        console.log(response);
                        addToCartButton.disabled = true;
                        errorMessage.style.display = 'block';
                        errorMessage.innerText = 'Trek not selected. Please book your trek first to rent the products.';
                        // Redirect to the specified URL
                        setTimeout(function () {
                            errorMessage.style.display = 'none';
                        }, 4000);
                        // window.location.href = '/rent/renttrekdetailsform';
                    }
                },
                error: function () {
                    var errorMessage = document.getElementById('error-message');
                    errorMessage.style.display = 'block';
                    errorMessage.innerText = 'An error occurred while checking the TrekId.';

                    setTimeout(function () {
                        errorMessage.style.display = 'none';
                    }, 2000);
                }
            });
        }
    }

    // Ensure the DOM is loaded before updating hidden fields
    document.addEventListener("DOMContentLoaded", function () {
        updateHiddenFields();
    });
</script>

<!-- JavaScript to Jump to Specific Carousel Slide -->
<script>
    function goToSlide(index) {
        var carousel = new bootstrap.Carousel(document.getElementById('carouselRentProduct'));
        carousel.to(index);  // Jump to the selected slide based on the thumbnail clicked
    }
</script>
<script>

        var addToCartButton = document.getElementById('addToCartButton');
        if (addToCartButton) {
            addToCartButton.addEventListener('click', function (e) {

                var variantSelect = document.getElementById("variant");
               
                var selectedSizeName = variantSelect ? variantSelect.value : '';
              
                var errorMessage = document.getElementById("error-message");
            var successMessage = document.getElementById("successmessage");
               

                if (selectedSizeName === "") {
                    e.preventDefault();  // Prevent form submission
                    errorMessage.style.display = "block";
                    errorMessage.innerText = "Please select a size before adding to cart.";

                    setTimeout(function () {
                        errorMessage.style.display = 'none';
                    }, 3000);  // Error message disappears after 3 seconds
                } else if (selectedSizeName) {
                successMessage.style.display = "block";
                successMessage.innerText = "Item Added in cart";

                setTimeout(function () {
                    successMessage.style.display = 'none';
                }, 3000);  // Error message disappears after 3 seconds
                }
                else{
                    checkTrekIdInDatabase();  // Proceed with checking in the database
                }
            });
        } else {
            alert('Button not found!');
        }
  
</script>

