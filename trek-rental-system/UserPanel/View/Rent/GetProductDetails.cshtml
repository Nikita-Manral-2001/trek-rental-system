@model TTH.Areas.Super.Models.Rent.CombinedViewModel;

@{
    ViewData["Title"] = "Product Page";
}



<div class="container product-page">
    <div class="row shadow p-1 bg-white rounded">


        <div class="col-md-6 product-image">
            <!-- Carousel for Product Images -->

            <div id="carouselRentProduct" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-inner">
                    @for (int i = 0; i < Model.ProductVM.Product.Gallery?.Count; i++)
                    {
                        <div class="@(i == 0 ? "carousel-item active" : "carousel-item")">
                            <img src="@Model.ProductVM.Product.Gallery[i].URL" class="Carousel_Rent_image" width="300" height="300" alt="@Model.ProductVM.Product.Gallery[i].Name">
                        </div>
                    }
                </div>

                <!-- Carousel Controls -->
                <button class="carousel-control-prev" type="button" data-bs-target="#carouselRentProduct" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#carouselRentProduct" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            </div>

            <div class="row mt-5">
                <div class="d-flex flex-row justify-content-center align-items-center Product-Img-Thunbnail">
                    @for (int i = 0; i < Model.ProductVM.Product.Gallery?.Count; i++)
                    {
                        <div class="mx-2 Product-Img-Thunbnail-Img">
                            <img src="@Model.ProductVM.Product.Gallery[i].URL"
                                 class="img-fluid img-thumbnail"
                                 alt="@Model.ProductVM.Product.Gallery[i].Name"
                                 style="cursor: pointer; width: 120px; height:100px;"
                                 onclick="goToSlide(@i)" />
                        </div>
                    }
                </div>
            </div>
        </div>


        <div class="col-md-6 product-details">
            <div class="row">
            <div class="product-details-ProductName col-md-6"> 
                <p>@Model.ProductVM.Product.ProductName</p>
                </div>


            @if (Model.ProductVM.IsTrekBooked)
            {
                    <div class="product-details-price col-md-6">
                    <p>&#8377; @Model.ProductVM.TotalPrice</p>
                </div>

            }
            else
            {
                    <div class="product-details-price col-md-6">
                <p>Price per day : &#8377;@Model.ProductVM.Product.PricePerDay</p>
                    </div>
            }
            </div>
            <div class="product-description">

                @Html.Raw(Model.ProductVM.Product.Description)
            </div>
            <hr class="Rent-red-line" />

            <div id="error-message" class="alert alert-danger mt-3" style="display:none;"></div>
            <div id="successmessage" class="alert alert-success mt-3" style="display:none;"></div>

            <!-- Product Order Form -->
            <div class="product-order mt-4">
                <form asp-controller="RentCart" asp-action="AddToCart" method="post" onsubmit="return validateForm()">
                    <div class="form-group row">

                        <div class="col-12">
                            <label for="variant">Product Size</label>
                            <select class="form-control Size-red-border form-select" id="variant" name="variant" required>
                                <option value="">----Choose Size----</option>
                                @foreach (var size in Model.ProductVM.Product.Sizes)
                                {
                                    <option value="@size.S_Id">@size.Name</option>
                                }
                            </select>
                        </div>

                    </div>
                    <div class="row">
                        <div class="col-3 ">
                            <label for="quantity">Quantity</label>
                            <input type="number" class="form-control Size-red-border Rent-Quantity" id="quantity" name="quantity" value="1" min="1" required>
                        </div>
                        <div class="col-9">
                            <input type="hidden" name="blockEndDate" value="@Model.ProductVM.BlockEndDate" />
                            <input type="hidden" name="trekName" value="@Model.ProductVM.TrekName" />
                            <input type="hidden" name="variant" value="@Model.ProductVM.Variant" />
                            <input type="hidden" name="productId" value="@Model.ProductVM.Product.Products_Id" />
                            <input type="hidden" name="productName" value="@Model.ProductVM.Product.ProductName" />
                            <input type="hidden" name="totalPrice" value="@Model.ProductVM.TotalPrice" />
                            <input type="hidden" id="trekId" name="trekId" value="@Model.ProductVM.TrekId" />
                            <input type="hidden" id="startDate" name="startDate" value="@Model.ProductVM.StartDate.ToString("yyyy-MM-dd")" />
                            <input type="hidden" id="endDate" name="endDate" value="@Model.ProductVM.EndDate.ToString("yyyy-MM-dd")" />
                            <input type="hidden" id="departureId" name="departureId" value="@Model.ProductVM.DepartureId" />
                            <input type="hidden" name="coverImage" value="@Model.ProductVM.Product.Gallery?.FirstOrDefault()?.URL" />
                            <input type="hidden" name=" TotalPrice" value="@Model.ProductVM.TotalPrice" />
                            <input type="hidden" name="userId" value="@Model.ProductVM.UserId" />
                            <input type="hidden" name="userEmail" value="@Model.ProductVM.UserEmail" />
                            <button type="submit" class="AddToCart-Btn mt-4" id="addToCartButton">Add-To-Cart</button>
                        </div>

                    </div>

                </form>


                <!-- Error message for invalid conditions -->

            </div>
        </div>
    </div>






